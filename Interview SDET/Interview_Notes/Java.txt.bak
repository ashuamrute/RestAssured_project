		js.executeScript("arguments[0].click()", male);
		
	// 3) Scroll page to given coordinate
		
	js.executeScript("window.scrollBy(0,1000)", "");
	
	 
	 
	 //*******************************
	 Use Exixting chrome session
	 
	 public class LaunchChromeForExistingSession {

	public static void main(String[] args) {
		ChromeDriver driver = new ChromeDriver();
		System.out.println(driver.getCapabilities());   // chromeOptions: {debuggerAddress: localhost:56182}
		driver.get("https:www.google.com");
		

	}

}public class UseExixtingChromeSession {

	public static void main(String[] args) {
		ChromeOptions options = new ChromeOptions();
		// chromeOptions: {debuggerAddress: localhost:56182}
		options.setExperimentalOption("debuggerAddress", "localhost:56315");
		ChromeDriver driver = new ChromeDriver(options);
		driver.get("https://testautomationpractice.blogspot.com/");

	}

}

